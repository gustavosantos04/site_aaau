# Public data and admin write operations
DATABASE_URL="postgresql://usuario:senha@localhost:5432/aaau_site?schema=public"

# Admin authentication
ADMIN_EMAIL="admin@exemplo.com"
ADMIN_PASSWORD="troque-esta-senha"
JWT_SECRET="change-this-to-a-long-random-secret-with-32-plus-chars"

# Trusted canonical origin. APP_URL is server-only; keep the public URL equal to it.
APP_URL="https://staging.example.com"
NEXT_PUBLIC_SITE_URL="https://aaau-uniritter.vercel.app"
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# Mercado Pago checkout
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""

# SMTP (required only when email delivery is enabled)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
ORDER_NOTIFICATION_EMAIL=""

# Optional event reservation duration (minutes)
EVENT_TICKET_RESERVATION_MINUTES="15"
