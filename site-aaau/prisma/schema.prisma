generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductCategory {
  APPAREL
  UNIFORM
  ACCESSORY
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED
}

enum OrderStatus {
  PENDING
  CONTACT_PENDING
  CONFIRMED
  PAID
  FULFILLED
  CANCELED
  FAILED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
  REFUNDED
  EXPIRED
  UNKNOWN
}

enum TicketEventStatus {
  DRAFT
  PUBLISHED
  SALES_OPEN
  SOLD_OUT
  FINISHED
  CANCELED
}

enum EventOrderStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
  EXPIRED
}

enum EventPaymentPreferenceStatus {
  NOT_CREATED
  CREATING
  CREATED
  AMBIGUOUS
}

enum EventTicketConfirmationEmailStatus {
  NOT_SENT
  SENDING
  SENT
  AMBIGUOUS
}

enum EmailDeliveryKind {
  EVENT_TICKET_CONFIRMATION
  STORE_ORDER_CONFIRMATION
  INTERNAL_ORDER_NOTIFICATION
}

enum EmailDeliveryStatus {
  PENDING
  SENDING
  SENT
  DELIVERED
  DELAYED
  BOUNCED
  FAILED
  COMPLAINED
  SUPPRESSED
}

enum EventTicketStatus {
  VALID
  USED
  CANCELED
  REFUNDED
}

enum EventPartnerType {
  ATHLETIC
  PARTNER
  PROMOTION
  OTHER
}

enum EventPartnerDiscountType {
  PERCENTAGE
  FIXED
}

enum EventCheckInAction {
  QR_VALIDATE
  QR_CONFIRM
  MANUAL_CONFIRM
  ADMIN_REVERSAL
}

enum EventCheckInResult {
  VALID
  CHECKED_IN
  ALREADY_USED
  INVALID
  WRONG_EVENT
  UNAUTHORIZED
  REVERSED
}

model Product {
  id                    String          @id @default(cuid())
  name                  String
  slug                  String          @unique
  price                 Decimal         @db.Decimal(10, 2)
  description           String          @db.Text
  metadata              Json?
  category              ProductCategory
  sizes                 String[]
  stock                 Int             @default(0)
  requiresCustomization Boolean         @default(false)
  featured              Boolean         @default(false)
  isNew                 Boolean         @default(false)
  isActive              Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  images                ProductImage[]
  orderItems            OrderItem[]
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Coupon {
  id            String             @id @default(cuid())
  code          String             @unique
  description   String?            @db.Text
  discountType  CouponDiscountType
  discountValue Decimal            @db.Decimal(10, 2)
  isActive      Boolean            @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  orders        Order[]
}

model Order {
  id                      String          @id @default(cuid())
  orderNumber             String          @unique
  customerName            String
  customerCpf             String?
  customerEmail           String
  customerPhone           String
  customerCampus          String?
  notes                   String?         @db.Text
  fulfillmentType         String          @default("WHATSAPP_CONTACT")
  status                  OrderStatus     @default(PENDING)
  paymentStatus           PaymentStatus   @default(PENDING)
  paymentProvider         String          @default("MERCADO_PAGO")
  checkoutSessionKey      String?         @unique
  mercadoPagoPreferenceId String?
  mercadoPagoInitPoint    String?         @db.Text
  mercadoPagoPaymentId    String?
  paymentMethodId         String?
  paymentTypeId           String?
  statusDetail            String?
  paidAt                  DateTime?
  subtotal                Decimal         @db.Decimal(10, 2)
  discount                Decimal         @default(0) @db.Decimal(10, 2)
  total                   Decimal         @db.Decimal(10, 2)
  customerCpfHash         String?
  customerCpfLast4        String?
  couponId                String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  coupon                  Coupon?         @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items                   OrderItem[]
  paymentEvents           PaymentEvent[]
  emailDeliveries         EmailDelivery[]

  @@unique([mercadoPagoPaymentId])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([mercadoPagoPreferenceId])
  @@index([checkoutSessionKey])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String?
  productName  String
  productSlug  String
  size         String?
  customName   String?
  customNumber String?
  quantity     Int
  unitPrice    Decimal  @db.Decimal(10, 2)
  lineTotal    Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model AdminUser {
  id                  String                 @id @default(cuid())
  name                String
  email               String                 @unique
  passwordHash        String
  role                String                 @default("ADMIN")
  isActive            Boolean                @default(true)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  checkedEventTickets EventTicket[]
  eventCheckInLogs    EventCheckInLog[]
  eventAuditLogs      EventAdminAuditLog[]
  eventAssignments    EventStaffAssignment[] @relation("EventStaffAssignmentUser")
  createdAssignments  EventStaffAssignment[] @relation("EventStaffAssignmentCreator")
}

model Event {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  excerpt    String   @db.Text
  startsAt   DateTime
  location   String
  coverImage String?
  isFeatured Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([startsAt, isFeatured])
}

model ManagementAreaRecord {
  id        String                   @id @default(cuid())
  slug      String                   @unique
  title     String
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
  members   ManagementMemberRecord[]
}

model ManagementMemberRecord {
  id        String               @id @default(cuid())
  areaId    String
  name      String
  role      String?
  image     String?
  instagram String?
  sortOrder Int                  @default(0)
  isActive  Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  area      ManagementAreaRecord @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@index([areaId, sortOrder])
}

model PaymentEvent {
  id                   String      @id @default(cuid())
  orderId              String?
  eventOrderId         String?
  provider             String
  eventType            String
  mercadoPagoPaymentId String?
  webhookRequestId     String?     @unique
  status               String?
  payload              Json
  createdAt            DateTime    @default(now())
  order                Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  eventOrder           EventOrder? @relation(fields: [eventOrderId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([eventOrderId, createdAt])
  @@index([mercadoPagoPaymentId])
}

model TicketEvent {
  id                      String                 @id @default(cuid())
  name                    String
  slug                    String                 @unique
  shortDescription        String                 @db.Text
  description             String                 @db.Text
  bannerImage             String?
  coverImage              String?
  startAt                 DateTime
  endAt                   DateTime?
  salesStartAt            DateTime?
  salesEndAt              DateTime?
  venueName               String
  venueAddress            String?
  minimumAge              Int?
  status                  TicketEventStatus      @default(DRAFT)
  published               Boolean                @default(false)
  showRemainingTickets    Boolean                @default(false)
  maxTicketsPerOrder      Int                    @default(4)
  lowStockThreshold       Int                    @default(10)
  requireParticipantEmail Boolean                @default(false)
  requireParticipantPhone Boolean                @default(false)
  requireBirthDate        Boolean                @default(false)
  requireInstitution      Boolean                @default(false)
  requireCourse           Boolean                @default(false)
  requireCampus           Boolean                @default(false)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  lots                    EventTicketLot[]
  partnerCodes            EventPartnerCode[]
  orders                  EventOrder[]
  tickets                 EventTicket[]
  checkInLogs             EventCheckInLog[]
  auditLogs               EventAdminAuditLog[]
  staffAssignments        EventStaffAssignment[]

  @@index([published, startAt])
  @@index([status, startAt])
  @@index([salesStartAt, salesEndAt])
}

model EventStaffAssignment {
  id                   String      @id @default(cuid())
  eventId              String
  adminUserId          String
  active               Boolean     @default(true)
  createdAt            DateTime    @default(now())
  createdByAdminUserId String?
  updatedAt            DateTime    @updatedAt
  event                TicketEvent @relation(fields: [eventId], references: [id], onDelete: Restrict)
  adminUser            AdminUser   @relation("EventStaffAssignmentUser", fields: [adminUserId], references: [id], onDelete: Restrict)
  createdByAdminUser   AdminUser?  @relation("EventStaffAssignmentCreator", fields: [createdByAdminUserId], references: [id], onDelete: SetNull)

  @@unique([eventId, adminUserId])
  @@index([adminUserId, active])
  @@index([eventId, active])
}

model EventTicketLot {
  id               String                  @id @default(cuid())
  eventId          String
  name             String
  description      String?                 @db.Text
  price            Decimal                 @db.Decimal(10, 2)
  quantity         Int
  reservedQuantity Int                     @default(0)
  soldQuantity     Int                     @default(0)
  salesStartAt     DateTime?
  salesEndAt       DateTime?
  position         Int                     @default(0)
  active           Boolean                 @default(true)
  autoActivate     Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  event            TicketEvent             @relation(fields: [eventId], references: [id], onDelete: Restrict)
  participants     EventOrderParticipant[]
  tickets          EventTicket[]

  @@index([eventId, position])
  @@index([eventId, active, salesStartAt, salesEndAt])
}

model EventPartnerCode {
  id            String                   @id @default(cuid())
  eventId       String
  code          String
  partnerName   String
  partnerType   EventPartnerType         @default(PARTNER)
  discountType  EventPartnerDiscountType
  discountValue Decimal                  @db.Decimal(10, 2)
  maxUses       Int?
  reservedUses  Int                      @default(0)
  confirmedUses Int                      @default(0)
  startsAt      DateTime?
  expiresAt     DateTime?
  active        Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  event         TicketEvent              @relation(fields: [eventId], references: [id], onDelete: Restrict)
  orders        EventOrder[]

  @@unique([eventId, code])
  @@index([eventId, active])
  @@index([code])
}

model EventOrder {
  id                                 String                             @id @default(cuid())
  eventId                            String
  buyerName                          String
  buyerCpf                           String?
  buyerCpfHash                       String?
  buyerCpfLast4                      String?
  buyerEmail                         String
  buyerPhone                         String
  partnerCodeId                      String?
  subtotal                           Decimal                            @db.Decimal(10, 2)
  discountAmount                     Decimal                            @default(0) @db.Decimal(10, 2)
  total                              Decimal                            @db.Decimal(10, 2)
  status                             EventOrderStatus                   @default(PENDING)
  mercadoPagoPreferenceId            String?
  mercadoPagoInitPoint               String?                            @db.Text
  mercadoPagoSandboxInitPoint        String?                            @db.Text
  paymentPreferenceStatus            EventPaymentPreferenceStatus       @default(NOT_CREATED)
  paymentPreferenceCreationStartedAt DateTime?
  paymentPreferenceLastErrorAt       DateTime?
  ticketConfirmationEmailStatus      EventTicketConfirmationEmailStatus @default(NOT_SENT)
  ticketConfirmationEmailStartedAt   DateTime?
  ticketConfirmationEmailSentAt      DateTime?
  ticketConfirmationEmailLastErrorAt DateTime?
  mercadoPagoPaymentId               String?
  paymentMethodId                    String?
  paymentTypeId                      String?
  statusDetail                       String?
  externalReference                  String                             @unique
  idempotencyKey                     String?                            @unique
  payloadFingerprint                 String?
  accessToken                        String                             @unique
  expiresAt                          DateTime
  paidAt                             DateTime?
  canceledAt                         DateTime?
  createdAt                          DateTime                           @default(now())
  updatedAt                          DateTime                           @updatedAt
  event                              TicketEvent                        @relation(fields: [eventId], references: [id], onDelete: Restrict)
  partnerCode                        EventPartnerCode?                  @relation(fields: [partnerCodeId], references: [id], onDelete: SetNull)
  participants                       EventOrderParticipant[]
  tickets                            EventTicket[]
  paymentEvents                      PaymentEvent[]
  emailDeliveries                    EmailDelivery[]

  @@unique([mercadoPagoPaymentId])
  @@index([eventId, status, createdAt])
  @@index([status, expiresAt])
  @@index([mercadoPagoPreferenceId])
  @@index([partnerCodeId])
  @@index([idempotencyKey])
  @@index([payloadFingerprint])
  @@index([ticketConfirmationEmailStatus, ticketConfirmationEmailStartedAt])
}

model EmailDelivery {
  id              String               @id @default(cuid())
  provider        String               @default("RESEND")
  providerEmailId String?              @unique
  kind            EmailDeliveryKind
  status          EmailDeliveryStatus  @default(PENDING)
  idempotencyKey  String               @unique
  orderId         String?
  eventOrderId    String?
  sender          String
  recipient       String
  subject         String
  attemptCount    Int                  @default(0)
  lastAttemptAt   DateTime?
  sentAt          DateTime?
  deliveredAt     DateTime?
  failedAt        DateTime?
  complainedAt    DateTime?
  lastEventAt     DateTime?
  lastError       String?              @db.Text
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  order           Order?               @relation(fields: [orderId], references: [id], onDelete: SetNull)
  eventOrder      EventOrder?          @relation(fields: [eventOrderId], references: [id], onDelete: SetNull)
  events          EmailDeliveryEvent[]

  @@index([orderId, createdAt])
  @@index([eventOrderId, createdAt])
  @@index([status, createdAt])
  @@index([recipient, createdAt])
}

model EmailDeliveryEvent {
  id              String         @id @default(cuid())
  providerEventId String         @unique
  providerEmailId String
  emailDeliveryId String?
  type            String
  occurredAt      DateTime
  payload         Json
  createdAt       DateTime       @default(now())
  emailDelivery   EmailDelivery? @relation(fields: [emailDeliveryId], references: [id], onDelete: SetNull)

  @@index([providerEmailId, occurredAt])
  @@index([emailDeliveryId, occurredAt])
  @@index([type, occurredAt])
}

model EventOrderParticipant {
  id           String         @id @default(cuid())
  eventOrderId String
  ticketLotId  String
  name         String
  cpf          String
  cpfHash      String?
  cpfLast4     String?
  email        String?
  phone        String?
  birthDate    DateTime?
  institution  String?
  course       String?
  campus       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  eventOrder   EventOrder     @relation(fields: [eventOrderId], references: [id], onDelete: Restrict)
  ticketLot    EventTicketLot @relation(fields: [ticketLotId], references: [id], onDelete: Restrict)
  ticket       EventTicket?

  @@index([eventOrderId])
  @@index([ticketLotId])
  @@index([cpfHash])
}

model EventTicket {
  id                  String                @id @default(cuid())
  eventOrderId        String
  eventId             String
  lotId               String
  orderParticipantId  String                @unique
  participantName     String
  participantCpf      String?
  participantCpfHash  String?
  participantCpfLast4 String?
  participantEmail    String?
  participantPhone    String?
  birthDate           DateTime?
  institution         String?
  course              String?
  campus              String?
  ticketCode          String                @unique
  qrToken             String                @unique
  status              EventTicketStatus
  issuedAt            DateTime              @default(now())
  checkedInAt         DateTime?
  checkedInByUserId   String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  eventOrder          EventOrder            @relation(fields: [eventOrderId], references: [id], onDelete: Restrict)
  event               TicketEvent           @relation(fields: [eventId], references: [id], onDelete: Restrict)
  lot                 EventTicketLot        @relation(fields: [lotId], references: [id], onDelete: Restrict)
  orderParticipant    EventOrderParticipant @relation(fields: [orderParticipantId], references: [id], onDelete: Restrict)
  checkedInBy         AdminUser?            @relation(fields: [checkedInByUserId], references: [id], onDelete: SetNull)
  checkInLogs         EventCheckInLog[]

  @@index([eventId, status])
  @@index([eventOrderId])
  @@index([lotId])
  @@index([participantCpfHash])
  @@index([checkedInAt])
}

model EventCheckInLog {
  id          String             @id @default(cuid())
  ticketId    String?
  eventId     String
  adminUserId String?
  action      EventCheckInAction
  result      EventCheckInResult
  deviceInfo  String?
  createdAt   DateTime           @default(now())
  ticket      EventTicket?       @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  event       TicketEvent        @relation(fields: [eventId], references: [id], onDelete: Restrict)
  adminUser   AdminUser?         @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([ticketId, createdAt])
  @@index([adminUserId, createdAt])
}

model EventAdminAuditLog {
  id          String       @id @default(cuid())
  eventId     String?
  adminUserId String?
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime     @default(now())
  event       TicketEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  adminUser   AdminUser?   @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([adminUserId, createdAt])
  @@index([targetType, targetId])
}
